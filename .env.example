MONGO_URI=mongodb://localhost:27017/
MONGO_DB=arbnb_MXN
MONGO_LISTINGS_COLLECTION=Listings
MONGO_REVIEWS_COLLECTION=Reviews
MONGO_CALENDAR_COLLECTION=Calendar
LOG_LEVEL=INFO

# Carga (SQLite / Excel)
SQLITE_DB_FILENAME=airbnb_transformado.db
# Max filas por cada archivo XLSX (trozo al partir Calendar, etc.)
EXCEL_MAX_ROWS_PER_FILE=100
# Max archivos XLSX por coleccion. Vacio = exportar todos los trozos.
# Ej. EXCEL_MAX_FILES=1 y EXCEL_MAX_ROWS_PER_FILE=2000 => solo 1 archivo ~2000 filas por tabla (preview).
EXCEL_MAX_FILES=1
SQLITE_TO_SQL_CHUNKSIZE=50000

